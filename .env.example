# Copy these values into your hosting provider's secret environment settings.
NODE_ENV=production
PORT=4173
HOST=0.0.0.0
TRUST_PROXY=1

# Comma-separated, exact public origins. Do not use * in production.
ALLOWED_ORIGINS=https://www.samaraorganics.in,https://samaraorganics.in

# Strong, unique credentials. Never commit real values.
ADMIN_USERNAME=replace-with-private-admin-name
ADMIN_PASSWORD=replace-with-a-long-random-password

# Encrypts short-lived idempotency responses that can contain private customer links.
IDEMPOTENCY_ENCRYPTION_KEY=replace-with-an-independent-long-random-secret

# Use a different long random secret for signed payment-provider webhooks.
PAYMENT_WEBHOOK_SECRET=replace-with-payment-webhook-secret

# Keep disabled until a real gateway has been integrated and verified.
PAYMENT_PROVIDER_ENABLED=0

# Optional provider-neutral alert endpoint. Error events contain request IDs and sanitized error metadata, never request bodies.
ERROR_MONITORING_WEBHOOK_URL=

# PIN prefixes currently planned around Aligarh and Bulandshahr.
SERVICEABLE_PIN_PREFIXES=202,203

# Use a persistent mounted path in production. Use :memory: only for automated tests.
DATABASE_PATH=./samara.db

# Store backups on persistent storage and retain the latest two weeks.
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14

# Used by the operations worker in compose.yaml.
BACKUP_INTERVAL_MINUTES=360
MAINTENANCE_INTERVAL_MINUTES=1440
OPERATIONS_MAX_CONSECUTIVE_FAILURES=3

# Operational metadata only. Orders/accounting records are not automatically deleted.
IDEMPOTENCY_RETENTION_DAYS=2
AUDIT_RETENTION_DAYS=730
CLOSED_SUPPORT_RETENTION_DAYS=730
